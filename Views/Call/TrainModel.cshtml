@{
    ViewData["Title"] = "Train Model";
}

<div class="train-wrap">
    <div class="train-card">
        <h2>Hand Coordinate Trainer</h2>
        <p>Start camera, click Detect Once, then save coordinates with label and description.</p>

        <div class="video-box">
            <video id="trainVideo" autoplay playsinline muted></video>
            <canvas id="trainCanvas"></canvas>
        </div>

        <div class="meta-form">
            <textarea id="coordsPreview" readonly placeholder="Detected coordinates will appear here..."></textarea>
            <input id="signLabel" type="text" placeholder="Label (example: hello)" disabled />
            <input id="signDescription" type="text" placeholder="Description (example: hi)" disabled />
            <span id="saveStatus" class="save-status"></span>
        </div>

        <div class="actions">
            <button id="startCameraBtn" class="btn" onclick="startCamera()">Start Camera</button>
            <button id="detectOnceBtn" class="btn once" onclick="detectOnce()" disabled>Detect Once</button>
            <button id="saveBtn" class="btn save" onclick="saveCoordinates()" disabled>Save Coordinates</button>
            <button id="chatBtn" class="btn chat" onclick="toggleChat()" disabled>Start Chat</button>
        </div>

        <div id="chatResult" class="chat-result">Detection result: -</div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/@@tensorflow/tfjs@4.20.0/dist/tf.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@@tensorflow-models/handpose@0.0.7/dist/handpose.min.js"></script>

<script>
    let model = null;
    let localStream = null;
    let lastDetectedCoords = null;
    let isChatRunning = false;
    let chatTimer = null;
    let savedSamples = [];

    const videoEl = document.getElementById("trainVideo");
    const canvasEl = document.getElementById("trainCanvas");
    const detectOnceBtn = document.getElementById("detectOnceBtn");
    const saveBtn = document.getElementById("saveBtn");
    const chatBtn = document.getElementById("chatBtn");
    const saveStatusEl = document.getElementById("saveStatus");
    const signLabelEl = document.getElementById("signLabel");
    const signDescriptionEl = document.getElementById("signDescription");
    const coordsPreviewEl = document.getElementById("coordsPreview");
    const chatResultEl = document.getElementById("chatResult");

    signLabelEl.addEventListener("input", refreshSaveState);

    async function startCamera() {
        try {
            if (!localStream) {
                localStream = await navigator.mediaDevices.getUserMedia({ video: true, audio: false });
                videoEl.srcObject = localStream;
            }
            detectOnceBtn.disabled = false;
            chatBtn.disabled = false;
            console.log("[TRAIN] Camera started");
        } catch (err) {
            console.error("[TRAIN] Camera start failed:", err);
            alert("Camera access failed.");
        }
    }

    async function ensureModel() {
        if (model) return model;
        await tf.setBackend("webgl");
        await tf.ready();
        model = await handpose.load();
        console.log("[TRAIN] Handpose model loaded");
        return model;
    }

    function drawLandmarks(predictions) {
        const w = Math.max(1, Math.floor(videoEl.clientWidth));
        const h = Math.max(1, Math.floor(videoEl.clientHeight));
        if (canvasEl.width !== w) canvasEl.width = w;
        if (canvasEl.height !== h) canvasEl.height = h;

        const ctx = canvasEl.getContext("2d");
        if (!ctx) return;
        ctx.clearRect(0, 0, canvasEl.width, canvasEl.height);

        const chains = [
            [0, 1, 2, 3, 4],
            [0, 5, 6, 7, 8],
            [0, 9, 10, 11, 12],
            [0, 13, 14, 15, 16],
            [0, 17, 18, 19, 20]
        ];

        for (const hand of predictions) {
            const points = hand.landmarks || [];
            ctx.strokeStyle = "rgba(34, 197, 94, 0.95)";
            ctx.lineWidth = 2;

            for (const chain of chains) {
                ctx.beginPath();
                chain.forEach((idx, i) => {
                    const p = points[idx];
                    if (!p) return;
                    const x = (p[0] / (videoEl.videoWidth || 1)) * canvasEl.width;
                    const y = (p[1] / (videoEl.videoHeight || 1)) * canvasEl.height;
                    if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
                });
                ctx.stroke();
            }

            ctx.fillStyle = "rgba(239, 68, 68, 0.95)";
            for (const p of points) {
                const x = (p[0] / (videoEl.videoWidth || 1)) * canvasEl.width;
                const y = (p[1] / (videoEl.videoHeight || 1)) * canvasEl.height;
                ctx.beginPath();
                ctx.arc(x, y, 3, 0, Math.PI * 2);
                ctx.fill();
            }
        }
    }

    async function detectOnce() {
        if (!videoEl.srcObject || videoEl.readyState < 2) {
            alert("Start camera first.");
            return;
        }

        try {
            const handModel = await ensureModel();
            await runDetectionCycle(handModel, true);
        } catch (err) {
            console.error("[TRAIN] Detect once failed:", err);
        }
    }

    async function runDetectionCycle(handModel, isSingle = false) {
        const predictions = await handModel.estimateHands(videoEl, false);
        drawLandmarks(predictions);

        if (!predictions || predictions.length === 0) {
            coordsPreviewEl.value = "";
            saveStatusEl.textContent = "No hand detected";
            lastDetectedCoords = null;
            signLabelEl.disabled = true;
            signDescriptionEl.disabled = true;
            refreshSaveState();
            if (isSingle) console.log("[TRAIN] No hand detected in this frame.");
            return;
        }

        const coords = mapPredictionsToCoords(predictions);

        lastDetectedCoords = coords;
        coordsPreviewEl.value = JSON.stringify(coords, null, 2);
        signLabelEl.disabled = false;
        signDescriptionEl.disabled = false;
        saveStatusEl.textContent = "Coordinates detected";
        refreshSaveState();
        console.log(isSingle ? "[TRAIN] Hand coordinates (single):" : "[TRAIN] Hand coordinates:", coords);
    }

    function mapPredictionsToCoords(predictions) {
        return predictions.map((h, idx) => ({
            hand: idx,
            points: (h.landmarks || []).map(p => ({
                x: Math.round(p[0]),
                y: Math.round(p[1]),
                z: Math.round(p[2] || 0)
            }))
        }));
    }

    async function saveCoordinates() {
        if (!lastDetectedCoords || lastDetectedCoords.length === 0) {
            alert("Detect coordinates first.");
            return;
        }

        const label = (signLabelEl.value || "").trim();
        const description = (signDescriptionEl.value || "").trim();

        if (!label) {
            alert("Please enter a label.");
            return;
        }

        const payload = {
            label: label,
            description: description || null,
            timeId: Date.now(),
            coordinates: lastDetectedCoords
        };

        try {
            const resp = await fetch("/Call/SaveSignCoordinate", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload)
            });

            const data = await resp.json();
            if (!resp.ok) throw new Error(data?.message || "Failed to save coordinates.");

            saveStatusEl.textContent = `Saved: ${label}`;
            await loadSavedSamples();
            console.log("[TRAIN] Coordinate saved:", data);
        } catch (err) {
            console.error("[TRAIN] Save failed:", err);
            saveStatusEl.textContent = "Save failed";
        }
    }

    async function loadSavedSamples() {
        const resp = await fetch("/Call/GetSignCoordinates");
        const data = await resp.json();
        if (!resp.ok) throw new Error("Failed to load saved coordinates.");

        savedSamples = (data || []).map(item => {
            let parsed = [];
            try {
                parsed = JSON.parse(item.coordinatesJson || "[]");
            } catch {
                parsed = [];
            }
            return {
                label: item.label || "",
                description: item.description || "",
                normalized: normalizeCoordinates(parsed)
            };
        }).filter(x => x.normalized.length > 0);
    }

    function normalizeCoordinates(coords) {
        if (!Array.isArray(coords) || coords.length === 0) return [];
        const firstHand = coords[0];
        if (!firstHand || !Array.isArray(firstHand.points) || firstHand.points.length === 0) return [];

        const points = firstHand.points;
        const origin = points[0];
        if (!origin) return [];

        let maxDistance = 0;
        const shifted = points.map(p => {
            const dx = p.x - origin.x;
            const dy = p.y - origin.y;
            const dz = (p.z || 0) - (origin.z || 0);
            const dist = Math.sqrt(dx * dx + dy * dy + dz * dz);
            if (dist > maxDistance) maxDistance = dist;
            return { dx, dy, dz };
        });

        const scale = maxDistance > 0 ? maxDistance : 1;
        return shifted.map(p => ({
            x: p.dx / scale,
            y: p.dy / scale,
            z: p.dz / scale
        }));
    }

    function calculateDistance(pointsA, pointsB) {
        if (!Array.isArray(pointsA) || !Array.isArray(pointsB) || pointsA.length !== pointsB.length) {
            return Number.POSITIVE_INFINITY;
        }

        let sum = 0;
        for (let i = 0; i < pointsA.length; i++) {
            const dx = pointsA[i].x - pointsB[i].x;
            const dy = pointsA[i].y - pointsB[i].y;
            const dz = pointsA[i].z - pointsB[i].z;
            sum += Math.sqrt(dx * dx + dy * dy + dz * dz);
        }

        return sum / pointsA.length;
    }

    function findBestMatch(currentCoords) {
        const currentNormalized = normalizeCoordinates(currentCoords);
        if (currentNormalized.length === 0 || savedSamples.length === 0) return null;

        let best = null;
        for (const sample of savedSamples) {
            const distance = calculateDistance(currentNormalized, sample.normalized);
            if (!best || distance < best.distance) {
                best = { sample, distance };
            }
        }

        const maxDistanceThreshold = 0.33;
        if (!best || best.distance > maxDistanceThreshold) return null;
        return best;
    }

    async function toggleChat() {
        if (isChatRunning) {
            stopChat();
            return;
        }

        if (!videoEl.srcObject || videoEl.readyState < 2) {
            alert("Start camera first.");
            return;
        }

        try {
            chatResultEl.textContent = "Detection result: loading samples...";
            await loadSavedSamples();
            if (savedSamples.length === 0) {
                chatResultEl.textContent = "Detection result: no saved signs.";
                return;
            }

            const handModel = await ensureModel();
            isChatRunning = true;
            chatBtn.textContent = "Stop Chat";

            chatTimer = setInterval(async () => {
                if (!isChatRunning || videoEl.readyState < 2) return;
                const predictions = await handModel.estimateHands(videoEl, false);
                drawLandmarks(predictions);

                if (!predictions || predictions.length === 0) {
                    chatResultEl.textContent = "Detection result: no hand";
                    return;
                }

                const currentCoords = mapPredictionsToCoords(predictions);
                const match = findBestMatch(currentCoords);
                if (!match) {
                    chatResultEl.textContent = "Detection result: no matching sign";
                    return;
                }

                const score = Math.max(0, 1 - (match.distance / 0.33));
                const confidence = Math.round(score * 100);
                chatResultEl.textContent = `Detection result: ${match.sample.label} (${confidence}%)`;
            }, 700);
        } catch (err) {
            console.error("[TRAIN] Chat detection failed:", err);
            chatResultEl.textContent = "Detection result: error";
            stopChat();
        }
    }

    function stopChat() {
        isChatRunning = false;
        if (chatTimer) {
            clearInterval(chatTimer);
            chatTimer = null;
        }
        chatBtn.textContent = "Start Chat";
    }

    function refreshSaveState() {
        const hasCoords = !!lastDetectedCoords && lastDetectedCoords.length > 0;
        const hasLabel = (signLabelEl.value || "").trim().length > 0;
        saveBtn.disabled = !(hasCoords && hasLabel);
    }
</script>

<style>
    .train-wrap {
        padding: 20px;
        display: flex;
        justify-content: center;
    }

    .train-card {
        width: min(100%, 920px);
        background: #fff;
        border: 1px solid #dbe4ee;
        border-radius: 18px;
        box-shadow: 0 16px 34px rgba(15, 23, 42, 0.08);
        padding: 20px;
    }

    .train-card h2 {
        margin: 0 0 6px;
    }

    .train-card p {
        margin: 0 0 14px;
        color: #475569;
    }

    .video-box {
        position: relative;
        width: 100%;
        aspect-ratio: 16 / 9;
        border-radius: 16px;
        overflow: hidden;
        background: #000;
        margin-bottom: 12px;
    }

    #trainVideo, #trainCanvas {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
    }

    #trainVideo {
        object-fit: cover;
    }

    #trainCanvas {
        pointer-events: none;
    }

    .actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .meta-form {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-bottom: 12px;
    }

    .meta-form input,
    .meta-form textarea {
        border: 1px solid #d1d5db;
        border-radius: 10px;
        padding: 10px 12px;
        outline: none;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    }

    #coordsPreview {
        grid-column: 1 / -1;
        min-height: 150px;
        resize: vertical;
        background: #f8fafc;
    }

    .save-status {
        display: inline-flex;
        align-items: center;
        min-height: 40px;
        color: #166534;
        font-weight: 600;
    }

    .btn {
        border: none;
        border-radius: 10px;
        padding: 10px 14px;
        color: #fff;
        cursor: pointer;
        background: #0f766e;
    }

    .btn.once {
        background: #2563eb;
    }

    .btn.save {
        background: #15803d;
    }

    .btn.chat {
        background: #ea580c;
    }

    .chat-result {
        margin-top: 12px;
        border: 1px solid #cbd5e1;
        border-radius: 10px;
        padding: 10px 12px;
        background: #f8fafc;
        color: #0f172a;
        font-weight: 600;
    }

    @@media (max-width: 760px) {
        .meta-form {
            grid-template-columns: 1fr;
        }
    }
</style>
