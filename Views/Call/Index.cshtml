<!--
PSEUDOCODE / PLAN (detailed):
1. When host creates a meeting (startCall), automatically open a "Share" modal that contains the meeting link and share controls.
2. Add modal markup (backdrop + modal dialog) to the page. Modal contains:
   - readonly input with the meeting link
   - Copy button (copies link to clipboard)
   - WhatsApp button (opens share via WhatsApp)
   - Close button
3. Implement JS helper functions:
   - openShareModal(): populate modal input with current meeting link, show modal
   - closeShareModal(): hide modal
   - copyMeetingLinkModal(): copy modal input value using navigator.clipboard or fallback prompt
   - sendMeetingLinkModal(): build WhatsApp share url with encoded message and open it
4. Wire existing 'Share' button to openShareModal() and call openShareModal() after startCall for hosts.
5. Ensure backdrop click closes modal; clicking inside modal won't close it.
6. Keep existing desktop meetingLinkDisplay input in sync (set its value when opening modal).
7. Minimal, non-invasive changes: add modal markup near end of body and JS functions near existing script block.
-->
<!-- ============================================================= -->
<!-- SMART VIDEO CALL UI - SIMPLE HTML + CSS + JS VERSION -->
<!-- NOW WITH REAL CAMERA START (getUserMedia) -->
<!-- Save as index.html and open in browser (Use HTTPS or localhost) -->
<!-- ============================================================= -->

<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Smart Video Call</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@tensorflow/tfjs"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@tensorflow-models/hand-pose-detection"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@mediapipe/hands"></script>
    <style>
        :root {
        --brand-700: #128c7e;
        --brand-500: #22c55e;
        --surface: #ffffff;
        --surface-2: #f8fafc;
        --text-900: #0f172a;
        --text-700: #334155;
        --line: #dbe4ee;
        --danger: #ef4444;
        --hero-gradient: radial-gradient(circle at 10% 18%, rgba(34, 197, 94, 0.14), transparent 40%),
        radial-gradient(circle at 88% 82%, rgba(18, 140, 126, 0.16), transparent 42%),
        linear-gradient(180deg, #f8fafc 0%, #eef2f7 100%);
        --brand-gradient: linear-gradient(135deg, var(--brand-700) 0%, var(--brand-500) 100%);
        }

        body {
        margin: 0;
        font-family: "Segoe UI", "Trebuchet MS", sans-serif;
        background: var(--hero-gradient);
        color: var(--text-900);
        }

        .screen {
        min-height: calc(100vh - 120px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: clamp(14px, 3vw, 28px);
        }

        .card {
        background: linear-gradient(180deg, var(--surface) 0%, var(--surface-2) 100%);
        padding: clamp(20px, 3.5vw, 32px);
        border-radius: 24px;
        box-shadow: 0 20px 55px rgba(15, 23, 42, 0.1);
        border: 1px solid var(--line);
        width: 100%;
        max-width: 980px;
        }

        h2 {
        text-align: center;
        margin-bottom: 20px;
        letter-spacing: -.4px;
        }

        input,
        select,
        button {
        font-size: 14px;
        }

        input,
        select {
        width: 100%;
        padding: 12px;
        border-radius: 12px;
        border: 1px solid var(--line);
        box-sizing: border-box;
        background: #fff;
        color: var(--text-900);
        }

        input:focus,
        select:focus {
        outline: none;
        border-color: var(--brand-700);
        box-shadow: 0 0 0 3px rgba(18, 140, 126, 0.12);
        }

        .row {
        display: flex;
        gap: 10px;
        margin-bottom: 15px;
        }

        button {
        padding: 10px 15px;
        border-radius: 12px;
        border: 1px solid var(--line);
        cursor: pointer;
        height: 45px;
        background: #fff;
        color: var(--text-700);
        transition: transform .2s ease, box-shadow .2s ease, background .2s ease;
        }

        button:hover {
        transform: translateY(-1px);
        box-shadow: 0 8px 18px rgba(15, 23, 42, 0.1);
        }

        .primary {
        background: var(--brand-gradient);
        color: #fff;
        width: 100%;
        border: none;
        }

        .end {
        background: var(--danger);
        color: #fff;
        border: none;
        }

        #startScreen input,
        #startScreen select {
        margin-bottom: 12px;
        }

        #startScreen .call-type-row {
        display: flex;
        flex-wrap: nowrap;
        gap: 8px;
        }

        #startScreen .call-type-btn {
        flex: 1;
        background: #ef4444;
        color: #fff;
        border: none;
        height: 32px;
        padding: 4px 8px;
        font-size: 11px;
        border-radius: 8px;
        }

        #startScreen .call-type-btn.active {
        background: var(--brand-gradient);
        color: #fff;
        box-shadow: 0 8px 18px rgba(18, 140, 126, 0.28);
        }

        .videoGrid {
        display: grid;
        gap: 15px;
        margin-bottom: 20px;
        width: 100%;
        grid-template-columns: 1fr;
        /* Default */
        }

        .videoGrid.grid-1 {
        grid-template-columns: 1fr;
        }

        .videoGrid.grid-2 {
        grid-template-columns: 1fr 1fr;
        }

        .videoGrid.grid-3 {
        grid-template-columns: 1fr 1fr 1fr;
        }

        .videoGrid.grid-4,
        .videoGrid.grid-plus {
        grid-template-columns: 1fr 1fr;
        }

        .videoBox {
        background: #000;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        overflow: hidden;
        position: relative;
        aspect-ratio: 16 / 9;
        }

        video {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 20px
        }

        .controls {
        display: flex;
        justify-content: center;
        gap: 15px;
        margin-bottom: 20px
        }

        .controls button {
        background: #e5e7eb;
        transition: background 0.3s;
        }

        .controls .end {
        background: #ef4444;
        color: #fff
        }

        .btn-active {
        background: #22c55e !important;
        color: #fff !important;
        }

        .btn-inactive {
        background: #ef4444 !important;
        color: #fff !important;
        }

        .participant-badge {
        background: rgba(18, 140, 126, 0.08);
        color: var(--brand-700);
        padding: 6px 15px;
        border-radius: 999px;
        font-size: 14px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        box-shadow: 0 4px 10px rgba(15, 23, 42, 0.08);
        border: 1px solid rgba(18, 140, 126, 0.2);
        }

        /* Advanced UI Overlays */
        .user-overlay {
        position: absolute;
        top: 10px;
        left: 10px;
        background: rgba(0, 0, 0, 0.5);
        color: #fff;
        padding: 4px 10px;
        border-radius: 8px;
        font-size: 12px;
        pointer-events: none;
        z-index: 10;
        }

        .pip-btn {
        position: absolute;
        top: 10px;
        right: 10px;
        background: rgba(0, 0, 0, 0.5);
        color: #fff;
        border: none;
        border-radius: 50%;
        width: 32px;
        height: 32px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        z-index: 10;
        transition: background 0.3s;
        }

        .pip-btn:hover {
        background: rgba(0, 0, 0, 0.8);
        }

        .sign-detect-btn {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        background: rgba(0, 0, 0, 0.55);
        color: #fff;
        border: 1px solid rgba(255, 255, 255, 0.25);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        line-height: 1;
        user-select: none;
        position: absolute;
        bottom: 12px;
        right: 12px;
        z-index: 12;
        cursor: pointer;
        }

        .sign-detect-btn.active {
        background: #128c7e;
        box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.25);
        }

        .sign-landmark-canvas {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 9;
        }

        .avatar-overlay {
        position: absolute;
        inset: 0;
        background: #202124;
        display: none;
        /* Shown when camera off */
        align-items: center;
        justify-content: center;
        z-index: 5;
        }

        .avatar-circle {
        width: 80px;
        height: 80px;
        background: #128c7e;
        color: #fff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 32px;
        font-weight: bold;
        text-transform: uppercase;
        }

        .video-controls-overlay {
        position: absolute;
        bottom: 10px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        gap: 10px;
        background: rgba(0, 0, 0, 0.5);
        padding: 8px 12px;
        border-radius: 20px;
        z-index: 10;
        /* opacity: 0;*/
        transition: opacity 0.3s;
        }

        .videoBox:hover .video-controls-overlay {
        opacity: 1;
        }

        .video-controls-overlay button {
        width: 35px;
        height: 35px;
        border-radius: 50%;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 14px;
        padding: 0;
        transition: all 0.2s;
        }

        .v-btn-active {
        background: #22c55e;
        color: white;
        }

        .v-btn-inactive {
        background: #ef4444;
        color: white;
        }

        .v-btn-end {
        background: #ef4444;
        color: white;
        }

        .v-btn-hidden {
        display: none !important;
        }

        /* Lobby / Modal */
        #lobbyScreen {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.76);
        backdrop-filter: blur(3px);
        z-index: 1000;
        display: none;
        align-items: center;
        justify-content: center;
        color: #fff;
        text-align: center;
        }

        .link-toast {
        position: fixed;
        top: 20px;
        right: 20px;
        background: linear-gradient(180deg, var(--surface) 0%, var(--surface-2) 100%);
        color: var(--text-900);
        padding: 12px 20px;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.16);
        display: none;
        align-items: center;
        gap: 12px;
        z-index: 1002;
        border: 1px solid rgba(18, 140, 126, 0.2);
        }

        #emptyGridMsg {
        grid-column: 1 / -1;
        text-align: center;
        @* padding: 20px; *@
        color: #666;
        font-style: italic;
        }

        .chat {
        padding: 15px;
        display: flex;
        flex-direction: column;
        background: linear-gradient(180deg, var(--surface) 0%, var(--surface-2) 100%);
        border-radius: 20px;
        box-shadow: 0 12px 34px rgba(15, 23, 42, 0.08);
        width: 100%;
        box-sizing: border-box;
        border: 1px solid var(--line);
        }

        .signAssistBar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 10px 12px;
        border-radius: 14px;
        background: rgba(18, 140, 126, 0.08);
        border: 1px solid rgba(18, 140, 126, 0.2);
        margin-bottom: 12px;
        }

        .signAssistText {
        display: flex;
        flex-direction: column;
        gap: 2px;
        color: var(--text-900);
        }

        .signAssistText span {
        color: var(--brand-700);
        font-weight: 700;
        }

        .signAssistBar button {
        border: none;
        border-radius: 10px;
        padding: 8px 12px;
        background: var(--brand-700);
        color: white;
        font-weight: 600;
        }

        .signAssistBar button:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        }

        .messages {
        display: flex;
        flex-direction: column;
        gap: 8px;
        height: 140px;
        /**Roughly 2-3 messages */
        overflow-y: auto;
        margin-bottom: 15px;
        padding: 5px;
        }

        /* Fullscreen Overlay Chat Refinements */
        .videoBox:fullscreen .chat,
        .videoBox:-webkit-full-screen .chat {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        background: transparent !important;
        border: none !important;
        box-shadow: none !important;
        z-index: 100;
        display: flex;
        flex-direction: column;
        padding: 0;
        pointer-events: none;
        /* Let clicks pass through to video unless on interactive elements */
        }

        .videoBox:fullscreen .messages,
        .videoBox:-webkit-full-screen .messages {
        position: absolute;
        top: 60px;
        right: 20px;
        bottom: 100px;
        width: 320px;
        height: auto;
        background: transparent;
        overflow-y: auto;
        pointer-events: auto;
        scrollbar-width: none;
        /* Hide scrollbar for Firefox */
        }

        .videoBox:fullscreen .messages::-webkit-scrollbar,
        .videoBox:-webkit-full-screen .messages::-webkit-scrollbar {
        display: none;
        /* Hide scrollbar for Chrome/Safari */
        }

        .videoBox:fullscreen .chatInput,
        .videoBox:-webkit-full-screen .chatInput {
        position: absolute;
        bottom: 20px;
        left: 50%;
        transform: translateX(-50%);
        width: 90%;
        background: rgba(255, 255, 255, 0.9);
        pointer-events: auto;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        }

        .videoBox:fullscreen .message,
        .videoBox:-webkit-full-screen .message {
        background: rgba(40, 40, 40, 0.85) !important;
        backdrop-filter: blur(4px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: #ffffff !important;
        }

        .videoBox:fullscreen .message .user,
        .videoBox:-webkit-full-screen .message .user {
        color: #22c55e !important;
        /* Brighter green for contrast on dark bg */
        }

        .videoBox:fullscreen .message .text,
        .videoBox:-webkit-full-screen .message .text {
        color: #ffffff !important;
        }

        .videoBox:fullscreen .message .time,
        .videoBox:-webkit-full-screen .message .time {
        color: #cccccc !important;
        }

        .videoBox:fullscreen .message.small,
        .videoBox:-webkit-full-screen .message.small {
        color: #ffffff !important;
        }

        .message {
        max-width: 100%;
        padding: 8px 12px;
        border-radius: 8px;
        position: relative;
        font-size: 14px;
        line-height: 1.4;
        box-shadow: 0 1px 1px rgba(0, 0, 0, 0.1);
        display: flex;
        flex-direction: column;
        }

        .message.sent {
        align-self: flex-end;
        background: #d8fbe5;
        border-top-right-radius: 2px;
        }

        .message.received {
        align-self: flex-start;
        background: #ffffff;
        border-top-left-radius: 2px;
        border: 1px solid var(--line);
        }

        .message .user {
        font-size: 11px;
        font-weight: bold;
        color: #128c7e;
        margin-bottom: 2px;
        }

        .message .text {
        margin-bottom: 4px;
        color: var(--text-900);
        }

        .message .time {
        align-self: flex-end;
        font-size: 10px;
        color: #999;
        }

        .message.sign-message {
        border: 1px solid rgba(18, 140, 126, 0.25);
        background: #ecfdf5;
        }

        /* chat input styling */
        .chatInput {
        display: flex;
        gap: 8px;
        align-items: center;
        background: #eff4f8;
        padding: 10px;
        border-radius: 30px;
        }

        .chatInput input {
        flex: 1;
        border: none;
        outline: none;
        padding: 10px 15px;
        border-radius: 20px;
        background: #fff;
        font-size: 14px;
        }

        .chatInput button {
        background: var(--brand-700);
        color: white;
        border: none;
        border-radius: 50%;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: transform 0.2s;
        }

        .chatInput button:hover {
        transform: scale(1.1);
        background: #0f7569;
        }

        /* meeting link area: shown only to host */
        #meetingLinkContainer {
        margin-top: 12px;
        display: none;
        }

        /* Modal */
        .modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, .6);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        padding: 16px;
        box-sizing: border-box;
        }

        .modal {
        background: linear-gradient(180deg, var(--surface) 0%, var(--surface-2) 100%);
        border-radius: 12px;
        padding: 18px;
        width: 100%;
        max-width: 560px;
        min-width: 320px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, .4);
        max-height: 80vh;
        overflow: auto;
        box-sizing: border-box;
        border: 1px solid var(--line);
        }

        .modal h3 {
        margin: 0 0 12px 0;
        font-size: 18px
        }

        .linkBox {
        display: flex;
        gap: 8px;
        margin-bottom: 12px;
        align-items: center;
        }

        .linkBox input {
        flex: 1;
        padding: 10px;
        border-radius: 8px;
        border: 1px solid var(--line);
        min-width: 0;
        /* avoid flex overflow issues */
        }

        .modal-actions {
        display: flex;
        gap: 8px;
        justify-content: flex-end;
        margin-top: 8px
        }

        /* Clear legacy fullscreen behavior */
        :fullscreen .card,
        :-webkit-full-screen .card {
        display: flex;
        flex-direction: column;
        }

        @@media (max-width: 900px) {

        .videoGrid.grid-3,
        .videoGrid.grid-4,
        .videoGrid.grid-plus {
        grid-template-columns: 1fr 1fr;
        }
        }

        @@media (max-width: 640px) {
        .screen {
        min-height: auto;
        padding: 12px;
        }

        .row {
        flex-direction: column;
        }

        .videoGrid.grid-2,
        .videoGrid.grid-3,
        .videoGrid.grid-4,
        .videoGrid.grid-plus {
        grid-template-columns: 1fr;
        }

        .participant-badge {
        font-size: 12px;
        padding: 5px 10px;
        }

        .link-toast {
        top: 12px;
        right: 12px;
        left: 12px;
        width: auto;
        }
        }
    </style>
</head>

<body>
    <div id="linkToast" class="link-toast">
        <div style="flex: 1; font-size: 13px;">
            <strong>Meeting Link</strong><br />
            <span id="toastLinkText" style="color: #666; font-size: 11px;">Loading...</span>
        </div>
        <button class="primary" style="height: 35px; width: 60px; padding: 0; font-size: 12px"
                onclick="copyMeetingLink()">Copy</button>
        <button style="height: 35px; width: 35px; padding: 0; font-size: 18px; background: transparent; color: #999"
                onclick="closeLinkToast()">&times;</button>
    </div>

    <div id="admissionToast" class="admission-toast"
         style="position: fixed; top: 20px; left: 20px; background: #fff; color: #000; padding: 15px 20px; border-radius: 15px; box-shadow: 0 8px 30px rgba(0,0,0,0.15); display: none; align-items: center; gap: 15px; z-index: 10001; border: 1px solid #128c7e; width: auto; max-width: 350px;">
        <div class="avatar-circle" style="width: 40px; height: 40px; font-size: 18px; flex-shrink: 0;">👤</div>
        <div style="flex: 1; text-align: left;">
            <strong id="admissionMsg" style="font-size: 14px; display: block; margin-bottom: 2px;">User is
                knocking...</strong>
                <span style="font-size: 12px; color: #666;">Allow entry?</span>
            </div>
            <div style="display:flex; gap:8px;">
                <button class="primary" style="height:32px; padding: 0 12px; font-size: 12px; border-radius: 8px;"
                        onclick="handleAdmission(true)">Accept</button>
                <button class="end" style="height:32px; padding: 0 12px; font-size: 12px; border-radius: 8px;"
                        onclick="handleAdmission(false)">Deny</button>
            </div>
        </div>

        <!-- START -->
        <div class="screen" id="startScreen">
            <div class="card">
                <h2>Start Sign Connect Call</h2>

                <input id="nameInput" placeholder="Enter your name" />
                <div id="orgInputWrapper" style="display: none;">
                    <input id="orgInput" placeholder="Enter your organization" />
                </div>
                <input id="mobileInput" value="+91 " placeholder="Enter mobile number" style="display:none" />

                <div id="hostOptions" style="margin-top: 15px; text-align: left;">
                    <div class="small">Meeting Visibility:</div>
                    <select id="meetingTypeSelect" onchange="toggleOrgInput()"
                            style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #ddd; margin-top: 5px;">
                        <option value="public">Public (Anyone with link can join)</option>
                        <option value="org">Organization (Same org join directly, others knock)</option>
                        <option value="private">Private (All guests must knock)</option>
                    </select>
                </div>

                <div class="row call-type-row" style="margin-top: 15px;">
                    <button onclick="setCallType('internet')" id="internetBtn" class="call-type-btn active">Internet
                        Meeting</button>
                        <button onclick="setCallType('whatsapp')" id="whatsappBtn" class="call-type-btn">WhatsApp Call</button>
                    </div>


                    <button class="primary" onclick="startCall()">Start</button>

                    <div id="invitedNote" class="small" style="display:none;margin-top:12px"></div>
                    <!-- hidden: when a visitor opens ?room=..., this is prefilled -->
                    <input id="inviteRoomInput" type="hidden" />
                </div>
            </div>

            <!-- MEETING -->
            <div class="screen" id="meetingScreen" style="display:none">
                <div class="card" id="meetingCard">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                        <h2 style="margin: 0">Live Internet Meeting</h2>
                        <div id="participantBadge" class="participant-badge">👥 <span>0</span> Participants</div>
                    </div>

                    <div class="videoGrid" id="videoGrid">
                        <div class="videoBox" id="localVideoBox">
                            <div class="user-overlay" id="localUserName">You</div>
                            <div style="position: absolute; top: 10px; right: 10px; display: flex; gap: 5px; z-index: 10;">
                                <button class="pip-btn" style="position: static;"
                                        onclick="toggleElementFullScreen('localVideoBox')" title="Toggle Fullscreen">⤢</button>
                            </div>
                            <button id="signBtn_local" class="sign-detect-btn" onclick="toggleSignDetection('local')"
                                    title="Sign Detection">🤟</button>
                            <div class="avatar-overlay" id="localAvatar">
                                <div class="avatar-circle">?</div>
                            </div>
                            <video id="localVideo" autoplay playsinline muted></video>
                            <canvas id="signCanvas_local" class="sign-landmark-canvas"></canvas>
                            <!-- Per-Video Controls (Local) -->
                            <div class="video-controls-overlay">
                                <button id="vCam_local" class="v-btn-active" onclick="toggleCamera()" title="Toggle Camera">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M23 7l-7 5 7 5V7z"></path>
                                        <rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect>
                                    </svg>
                                </button>
                                <button id="vMic_local" class="v-btn-active" onclick="toggleMic()" title="Toggle Microphone">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"></path>
                                        <path d="M19 10v2a7 7 0 0 1-14 0v-2"></path>
                                        <line x1="12" y1="19" x2="12" y2="23"></line>
                                        <line x1="8" y1="23" x2="16" y2="23"></line>
                                    </svg>
                                </button>
                                <button class="v-btn-end" onclick="endCall()" title="End Call">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path
                                            d="M10.68 13.31a16 16 0 0 0 3.41 2.6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7 2 2 0 0 1 1.72 2v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.42 19.42 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91">
                                        </path>
                                        <line x1="23" y1="1" x2="1" y2="23"></line>
                                    </svg>
                                </button>
                            </div>
                        </div>
                        <div id="emptyGridMsg">Waiting for others to join...</div>
                    </div>
                    <div class="chat" id="mainChat">
                        <div class="signAssistBar" id="signAssistBar" style="display:none;">
                            <div class="signAssistText">
                                <strong>Detected Sign</strong>
                                <span id="detectedSignLabel">Waiting...</span>
                            </div>
                            <button id="toggleSpeakModeBtn" type="button" onclick="toggleSpeakMode()">Speak Mode: Off</button>
                            <button id="speakDetectedSignBtn" type="button" onclick="speakDetectedSign()"
                                    disabled>Speak</button>
                        </div>
                        <div class="messages" id="messages"></div>
                        <div class="chatInput">
                            <input id="messageInput" placeholder="Type message"
                                   onkeydown="if(event.key==='Enter') sendMessage()" />
                            <button onclick="sendMessage()">➤</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- LOBBY -->
            <div id="lobbyScreen">
                <div>
                    <div class="avatar-circle" style="margin: 0 auto 20px; width: 100px; height: 100px; font-size: 40px;">⌛
                    </div>
                    <h2>Waiting for host approval...</h2>
                    <p>The room owner has been notified of your request.</p>
                </div>
            </div>




            <script>
                let callType = "internet";
                let localStream = null;
                let remoteStream = null;
                let currentRoomId = null;
                let isHost = false;
                let userName = "";
                let userOrg = "";
                let invitedRoomVisibility = "";

                // SignalR connection
                const connection = new signalR.HubConnectionBuilder()
                .withUrl("/callHub")
                .withAutomaticReconnect()
                .build();

                // WebRTC variables
                let pcs = {}; // connectionId -> RTCPeerConnection
                let myId = "";
                let pendingJoiner = null; // Used by host to track who is knocking
                let peerNames = {}; // connectionId -> userName
                let handModel = null;
                let handModelPromise = null;
                let handDetectTimer = null;
                let handDetectTargetId = null;
                let savedSignSamples = [];
                let pendingDetectedSignLabel = "";
                let pendingDetectedSignSince = 0;
                let lastBroadcastDetectedSign = "";
                let currentDetectedSignLabel = "";
                let currentDetectedSentence = [];
                let signSentenceTimer = null;
                let speakModeEnabled = false;
                const SIGN_STABLE_MS = 1500;
                const SIGN_SENTENCE_GAP_MS = 2000;
                const peerConfiguration = {
                iceServers: [
                { urls: 'stun:stun.l.google.com:19302' },
                { urls: 'stun:stun1.l.google.com:19302' }
                ]
                };

                async function loadHandModel() {
                if (handModel) return handModel;
                if (handModelPromise) return await handModelPromise;
                if (!window.tf || !window.handPoseDetection) {
                throw new Error("TensorFlow or hand-pose-detection script not loaded.");
                }
                handModelPromise = (async () => {
                await tf.ready();
                const model = handPoseDetection.SupportedModels.MediaPipeHands;
                const loadedModel = await handPoseDetection.createDetector(model, {
                runtime: "mediapipe",
                solutionPath: "https://cdn.jsdelivr.net/npm/@@mediapipe/hands/",
                modelType: "full",
                maxHands: 2
                });
                handModel = loadedModel;
                console.log("[SIGN] Multi-hand detector loaded");
                return handModel;
                })();

                try {
                return await handModelPromise;
                } catch (err) {
                handModelPromise = null;
                throw err;
                }
                }

                async function loadSavedSignSamples() {
                if (savedSignSamples.length > 0) return savedSignSamples;
                const resp = await fetch('/Call/GetSignCoordinates');
                const data = await resp.json();
                if (!resp.ok) throw new Error('Failed to load saved sign coordinates.');

                savedSignSamples = (data || []).map(item => {
                let parsed = [];
                try {
                parsed = JSON.parse(item.coordinatesJson || '[]');
                } catch {
                parsed = [];
                }
                return {
                label: item.label || '',
                description: item.description || '',
                normalized: normalizeMeetingCoordinates(parsed)
                };
                }).filter(x => x.label && x.normalized.length > 0);

                return savedSignSamples;
                }

                function normalizeMeetingCoordinates(coords) {
                if (!Array.isArray(coords) || coords.length === 0) return [];

                return coords.slice(0, 2).flatMap(hand => {
                if (!hand || !Array.isArray(hand.points) || hand.points.length === 0) return [];
                const points = hand.points;
                const origin = points[0];
                if (!origin) return [];

                let maxDistance = 0;
                const shifted = points.map(p => {
                const dx = p.x - origin.x;
                const dy = p.y - origin.y;
                const dz = (p.z || 0) - (origin.z || 0);
                const dist = Math.sqrt(dx * dx + dy * dy + dz * dz);
                if (dist > maxDistance) maxDistance = dist;
                return { dx, dy, dz };
                });

                const scale = maxDistance > 0 ? maxDistance : 1;
                return shifted.map(p => ({
                x: p.dx / scale,
                y: p.dy / scale,
                z: p.dz / scale
                }));
                });
                }

                function calculateMeetingDistance(pointsA, pointsB) {
                if (!Array.isArray(pointsA) || !Array.isArray(pointsB) || pointsA.length !== pointsB.length) {
                return Number.POSITIVE_INFINITY;
                }

                let sum = 0;
                for (let i = 0; i < pointsA.length; i++) {
                const dx = pointsA[i].x - pointsB[i].x;
                const dy = pointsA[i].y - pointsB[i].y;
                const dz = pointsA[i].z - pointsB[i].z;
                sum += Math.sqrt(dx * dx + dy * dy + dz * dz);
                }
                return sum / pointsA.length;
                }

                function findMeetingSignMatch(coords) {
                const currentNormalized = normalizeMeetingCoordinates(coords);
                if (currentNormalized.length === 0 || savedSignSamples.length === 0) return null;

                let best = null;
                for (const sample of savedSignSamples) {
                const distance = calculateMeetingDistance(currentNormalized, sample.normalized);
                if (!best || distance < best.distance) {
                best = { sample, distance };
                }
                }

                const maxDistanceThreshold = 0.33;
                if (!best || best.distance > maxDistanceThreshold) return null;
                return best;
                }

                function updateDetectedSignUi(label, showBar = true) {
                const bar = document.getElementById('signAssistBar');
                const text = document.getElementById('detectedSignLabel');
                const speakBtn = document.getElementById('speakDetectedSignBtn');
                const speakModeBtn = document.getElementById('toggleSpeakModeBtn');
                if (!bar || !text || !speakBtn) return;

                if (!showBar) {
                bar.style.display = 'none';
                text.innerText = 'Waiting...';
                speakBtn.disabled = true;
                currentDetectedSignLabel = '';
                return;
                }

                bar.style.display = 'flex';
                currentDetectedSignLabel = label || '';
                text.innerText = label || 'Waiting...';
                speakBtn.disabled = !label;
                if (speakModeBtn) {
                speakModeBtn.innerText = `Speak Mode: ${speakModeEnabled ? 'On' : 'Off'}`;
                }
                }

                function toggleSpeakMode() {
                speakModeEnabled = !speakModeEnabled;
                updateDetectedSignUi(currentDetectedSignLabel || (currentDetectedSentence.join(' ').trim()), true);
                }

                function speakDetectedSign() {
                const textToSpeak = currentDetectedSentence.length > 0
                ? currentDetectedSentence.join(' ')
                : currentDetectedSignLabel;
                if (!textToSpeak) return;
                if (!('speechSynthesis' in window)) return;
                window.speechSynthesis.cancel();
                const utterance = new SpeechSynthesisUtterance(textToSpeak);
                utterance.lang = 'en-IN';
                window.speechSynthesis.speak(utterance);
                }

                function scheduleDetectedSentenceCommit() {
                if (signSentenceTimer) {
                clearTimeout(signSentenceTimer);
                }
                signSentenceTimer = setTimeout(async () => {
                await commitDetectedSentence();
                }, SIGN_SENTENCE_GAP_MS);
                }

                async function commitDetectedSentence() {
                if (signSentenceTimer) {
                clearTimeout(signSentenceTimer);
                signSentenceTimer = null;
                }

                const sentence = currentDetectedSentence.join(' ').trim();
                if (!sentence) return;

                await sendDetectedSignToChat(sentence);
                if (speakModeEnabled) {
                currentDetectedSignLabel = sentence;
                speakDetectedSign();
                }

                currentDetectedSentence = [];
                currentDetectedSignLabel = '';
                pendingDetectedSignLabel = '';
                pendingDetectedSignSince = 0;
                lastBroadcastDetectedSign = '';
                updateDetectedSignUi('', true);
                }

                async function handleLocalDetectedSign(coords) {
                const match = findMeetingSignMatch(coords);
                if (!match) {
                pendingDetectedSignLabel = '';
                pendingDetectedSignSince = 0;
                updateDetectedSignUi(currentDetectedSentence.join(' ').trim(), true);
                return;
                }

                const label = (match.sample.label || '').trim();
                updateDetectedSignUi(currentDetectedSentence.length > 0 ? `${currentDetectedSentence.join(' ')} ${label}` : label, true);

                if (!label) return;

                if (pendingDetectedSignLabel !== label) {
                pendingDetectedSignLabel = label;
                pendingDetectedSignSince = Date.now();
                return;
                }

                if (Date.now() - pendingDetectedSignSince < SIGN_STABLE_MS) {
                return;
                }

                if (lastBroadcastDetectedSign === label) {
                return;
                }

                lastBroadcastDetectedSign = label;
                currentDetectedSentence.push(label);
                currentDetectedSignLabel = currentDetectedSentence.join(' ');
                updateDetectedSignUi(currentDetectedSignLabel, true);
                scheduleDetectedSentenceCommit();
                }

                async function sendDetectedSignToChat(label) {
                if (!label || !currentRoomId) return;
                if (connection.state !== signalR.HubConnectionState.Connected) return;
                try {
                await connection.invoke("SendMessage", currentRoomId, userName, `[SIGN] ${label}`);
                } catch (err) {
                console.warn('[SIGN] Failed to send detected sign:', err);
                }
                }

                function getVideoElementForSign(targetId) {
                return targetId === 'local'
                ? document.getElementById('localVideo')
                : document.getElementById(`video_${targetId}`);
                }

                function getSignCanvas(targetId) {
                return targetId === 'local'
                ? document.getElementById('signCanvas_local')
                : document.getElementById(`signCanvas_${targetId}`);
                }

                function clearSignCanvas(targetId) {
                const canvas = getSignCanvas(targetId);
                if (!canvas) return;
                const ctx = canvas.getContext('2d');
                if (!ctx) return;
                ctx.clearRect(0, 0, canvas.width || canvas.clientWidth, canvas.height || canvas.clientHeight);
                }

                function drawHandLandmarks(targetId, videoEl, predictions) {
                const canvas = getSignCanvas(targetId);
                if (!canvas || !videoEl) return;
                const box = videoEl.getBoundingClientRect();
                const width = Math.max(1, Math.floor(box.width));
                const height = Math.max(1, Math.floor(box.height));
                if (canvas.width !== width) canvas.width = width;
                if (canvas.height !== height) canvas.height = height;

                const ctx = canvas.getContext('2d');
                if (!ctx) return;
                ctx.clearRect(0, 0, canvas.width, canvas.height);

                const fingerChains = [
                [0, 1, 2, 3, 4],
                [0, 5, 6, 7, 8],
                [0, 9, 10, 11, 12],
                [0, 13, 14, 15, 16],
                [0, 17, 18, 19, 20]
                ];

                for (const hand of predictions) {
                const points = hand.keypoints || [];
                ctx.strokeStyle = 'rgba(34, 197, 94, 0.95)';
                ctx.lineWidth = 3;
                for (const chain of fingerChains) {
                ctx.beginPath();
                chain.forEach((idx, i) => {
                const p = points[idx];
                if (!p) return;
                const x = (p.x / (videoEl.videoWidth || 1)) * canvas.width;
                const y = (p.y / (videoEl.videoHeight || 1)) * canvas.height;
                if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
                });
                ctx.stroke();
                }

                ctx.fillStyle = 'rgba(18, 140, 126, 0.95)';
                for (const p of points) {
                const x = (p.x / (videoEl.videoWidth || 1)) * canvas.width;
                const y = (p.y / (videoEl.videoHeight || 1)) * canvas.height;
                ctx.beginPath();
                ctx.arc(x, y, 2.5, 0, Math.PI * 2);
                ctx.fill();
                }
                }
                }

                function setSignButtonState(targetId, active) {
                const btnId = targetId === 'local' ? 'signBtn_local' : `signBtn_${targetId}`;
                const btn = document.getElementById(btnId);
                if (!btn) return;
                btn.classList.toggle('active', active);
                }

                function stopSignDetection() {
                if (handDetectTimer) {
                clearInterval(handDetectTimer);
                handDetectTimer = null;
                }
                if (handDetectTargetId) {
                clearSignCanvas(handDetectTargetId);
                setSignButtonState(handDetectTargetId, false);
                }
                handDetectTargetId = null;
                pendingDetectedSignLabel = '';
                pendingDetectedSignSince = 0;
                lastBroadcastDetectedSign = '';
                currentDetectedSentence = [];
                currentDetectedSignLabel = '';
                if (signSentenceTimer) {
                clearTimeout(signSentenceTimer);
                signSentenceTimer = null;
                }
                updateDetectedSignUi('', false);
                }

                async function toggleSignDetection(targetId) {
                if (handDetectTimer && handDetectTargetId === targetId) {
                stopSignDetection();
                console.log(`[SIGN] Stopped detection for ${targetId}`);
                return;
                }

                stopSignDetection();
                const videoEl = getVideoElementForSign(targetId);

                if (!videoEl || videoEl.readyState < 2) {
                console.warn(`[SIGN] Video not ready for ${targetId}`);
                return;
                }

                try {
                const model = await loadHandModel();
                if (targetId === 'local') {
                await loadSavedSignSamples();
                updateDetectedSignUi('', true);
                }
                handDetectTargetId = targetId;
                setSignButtonState(targetId, true);
                console.log(`[SIGN] Started detection for ${targetId}`);

                handDetectTimer = setInterval(async () => {
                if (!videoEl || videoEl.readyState < 2) return;
                const predictions = await model.estimateHands(videoEl, { flipHorizontal: false });
                drawHandLandmarks(targetId, videoEl, predictions);
                const coords = predictions.map((h, idx) => ({
                hand: idx,
                points: (h.keypoints || []).map(p => ({ x: Math.round(p.x || 0), y: Math.round(p.y || 0), z: Math.round(p.z || 0) }))
                }));
                console.log(`[SIGN] ${targetId} hands detected: ${predictions.length}`, coords);
                if (targetId === 'local') {
                await handleLocalDetectedSign(coords);
                }
                }, 900);
                } catch (err) {
                console.error("[SIGN] Failed to start detection:", err);
                stopSignDetection();
                }
                }

                function isInvitedGuest() {
                const inviteRoom = document.getElementById('inviteRoomInput');
                return !!(inviteRoom && inviteRoom.value.trim());
                }

                function updateCallTypeButtons() {
                const internetBtn = document.getElementById('internetBtn');
                const whatsappBtn = document.getElementById('whatsappBtn');
                if (!internetBtn || !whatsappBtn) return;

                internetBtn.classList.toggle('active', callType === 'internet');
                whatsappBtn.classList.toggle('active', callType === 'whatsapp');
                }

                function refreshStartFields() {
                const mobileInput = document.getElementById('mobileInput');
                const hostOptions = document.getElementById('hostOptions');
                const orgWrapper = document.getElementById('orgInputWrapper');
                const meetingTypeSelect = document.getElementById('meetingTypeSelect');
                const invitedGuest = isInvitedGuest();
                updateCallTypeButtons();

                if (callType === 'whatsapp') {
                if (hostOptions) hostOptions.style.display = 'none';
                if (orgWrapper) orgWrapper.style.display = 'none';
                if (mobileInput) {
                mobileInput.style.display = 'block';
                if (!mobileInput.value || mobileInput.value.trim() === '') {
                mobileInput.value = '+91 ';
                }
                }
                return;
                }

                if (mobileInput) mobileInput.style.display = 'none';

                if (invitedGuest) {
                if (hostOptions) hostOptions.style.display = 'none';
                if (orgWrapper) orgWrapper.style.display = invitedRoomVisibility === 'org' ? 'block' : 'none';
                return;
                }

                if (hostOptions) hostOptions.style.display = 'block';
                if (orgWrapper && meetingTypeSelect) {
                orgWrapper.style.display = (meetingTypeSelect.value === 'org') ? 'block' : 'none';
                }
                }

                function setCallType(type) {
                callType = type;
                refreshStartFields();
                }

                async function startCall() {
                userName = document.getElementById('nameInput').value.trim();
                userOrg = document.getElementById('orgInput').value.trim();
                const customRoom = document.getElementById('inviteRoomInput').value.trim();
                const selectedMeetingType = document.getElementById('meetingTypeSelect').value;
                const effectiveMeetingType = customRoom ? (invitedRoomVisibility || selectedMeetingType) : selectedMeetingType;
                const startingAsHost = customRoom === '';

                if (!userName) { alert('Please enter your name'); return; }
                if (callType !== 'whatsapp' && effectiveMeetingType === 'org' && !userOrg) {
                alert('Please enter your Organization Name to start an Organization Meeting.');
                return;
                }

                if (callType === 'whatsapp') {
                const mobile = document.getElementById('mobileInput').value.trim();
                const mobileDigits = mobile.replace(/\D/g, '');
                if (!mobile || mobileDigits.length <= 2) { alert('Please enter mobile number after +91'); return; }
                window.open('https://wa.me/' + mobileDigits, '_blank');
                return;
                }

                isHost = startingAsHost;
                const roomId = customRoom || generateRoomId();
                currentRoomId = roomId;

                try { history.replaceState(null, '', `?room=${encodeURIComponent(roomId)}`); } catch (e) { }

                // Set up local UI initials
                const localAvatar = document.querySelector('#localAvatar .avatar-circle');
                if (localAvatar) localAvatar.innerText = userName.charAt(0);

                await startCamera();

                try {
                if (connection.state === signalR.HubConnectionState.Disconnected) {
                console.log("Starting SignalR connection...");
                await connection.start();
                console.log("SignalR connected:", connection.connectionId);
                }

                // Show knocking screen if we expect to be knocked or wait for approval
                // The Hub will tell us if we are admitted immediately
                if (!isHost) {
                console.log("Guest mode: showing lobby screen");
                document.getElementById('lobbyScreen').style.display = 'flex';
                }

                console.log("Invoking RequestToJoin:", { roomId: currentRoomId, userName, userOrg, meetingType: effectiveMeetingType });
                await connection.invoke("RequestToJoin", currentRoomId, userName, userOrg, effectiveMeetingType);
                } catch (err) {
                console.error("SignalR Connection/Invoke Error: ", err);
                alert("Failed to connect or join: " + err.message);
                }
                }

                function proceedToMeeting(type) {
                document.getElementById('startScreen').style.display = 'none';
                document.getElementById('lobbyScreen').style.display = 'none';
                document.getElementById('meetingScreen').style.display = 'flex';

                const meetingUrl = buildMeetingUrl(currentRoomId);
                const linkDisplay = document.getElementById('meetingLinkDisplay');
                if (linkDisplay) linkDisplay.value = meetingUrl;

                showLinkToast(meetingUrl, type);
                updateGridPlaceholder();
                }

                function showLinkToast(url, type) {
                const toast = document.getElementById('linkToast');
                const text = document.getElementById('toastLinkText');
                if (toast && text) {
                const typeLabel = type ? ` - ${type.charAt(0).toUpperCase() + type.slice(1)} Meeting` : '';
                text.innerText = url + typeLabel;
                toast.style.display = 'flex';
                // Auto-hide after 15 seconds
                setTimeout(() => closeLinkToast(), 15000);
                }
                }

                function closeLinkToast() {
                const toast = document.getElementById('linkToast');
                if (toast) toast.style.display = 'none';
                }

                async function startCamera() {
                try {
                localStream = await navigator.mediaDevices.getUserMedia({ video: true, audio: true });
                const videoEl = document.getElementById('localVideo');
                videoEl.srcObject = localStream;

                // Hide avatar when local video actually starts playing
                videoEl.onplay = () => {
                const avatar = document.getElementById('localAvatar');
                if (avatar) avatar.style.display = 'none';
                };

                videoEl.addEventListener('dblclick', () => toggleFullScreen());
                document.addEventListener('fullscreenchange', onFullScreenChange);
                } catch (err) {
                alert('Camera/Microphone permission denied or not available');
                console.error(err);
                }
                }

                // WebRTC functions
                // WebRTC functions
                async function createPeerConnection(targetId, isOfferer) {
                if (pcs[targetId]) return pcs[targetId];

                console.log("Creating peer connection for:", targetId);
                const pc = new RTCPeerConnection(peerConfiguration);
                pcs[targetId] = pc;

                // Add local tracks to connection
                if (localStream) {
                localStream.getTracks().forEach(track => {
                pc.addTrack(track, localStream);
                });
                }

                pc.onicecandidate = event => {
                if (event.candidate) {
                connection.invoke("SendIceCandidate", targetId, event.candidate);
                }
                };

                pc.ontrack = event => {
                console.log("OnTrack for:", targetId);
                const stream = event.streams[0] || new MediaStream([event.track]);

                const name = peerNames[targetId] || "Guest";
                const videoBox = getOrCreateVideoBox(targetId, name);
                const videoEl = document.getElementById(`video_${targetId}`);

                if (videoEl) {
                videoEl.srcObject = stream;
                // Ensure the onplay event is attached
                videoEl.onplay = () => {
                const avatar = document.getElementById(`avatar_${targetId}`);
                if (avatar) avatar.style.display = 'none';
                };
                }
                updateGridPlaceholder();
                };

                if (isOfferer) {
                console.log("Creating offer for:", targetId);
                const offer = await pc.createOffer();
                await pc.setLocalDescription(offer);
                await connection.invoke("SendOffer", targetId, offer);
                }

                return pc;
                }

                function removePeerConnection(targetId) {
                if (pcs[targetId]) {
                pcs[targetId].close();
                delete pcs[targetId];
                }
                if (handDetectTargetId === targetId) {
                stopSignDetection();
                }
                const box = document.getElementById(`box_${targetId}`);
                if (box) box.remove();
                }

                // SignalR Listeners
                connection.on("JoinedRoom", async (id, otherPeers, visibility, isActuallyHost) => {
                myId = id;
                console.log("My ID:", myId, "Host:", isActuallyHost);
                isHost = isActuallyHost;

                proceedToMeeting(visibility);

                if (Array.isArray(otherPeers)) {
                console.log("Syncing existing peers:", otherPeers.length);
                for (const peer of otherPeers) {
                // Handle both camelCase and PascalCase from server
                const peerId = peer.id || peer.Id || (typeof peer === 'string' ? peer : null);
                const peerName = peer.name || peer.Name || "Guest";

                if (peerId && peerId !== myId) {
                console.log("Adding peer:", peerName, peerId);
                peerNames[peerId] = peerName;
                getOrCreateVideoBox(peerId, peerName);
                await createPeerConnection(peerId, true);
                }
                }
                }
                updateGridPlaceholder();
                });

                connection.on("UserJoined", async (user, connId) => {
                console.log("User joined:", user, connId);
                peerNames[connId] = user;

                getOrCreateVideoBox(connId, user);

                const div = document.createElement('div');
                div.className = 'message small';
                div.style.textAlign = 'center';
                div.innerText = `${user} joined the room`;
                const msgs = document.getElementById('messages');
                if (msgs) msgs.appendChild(div);

                updateGridPlaceholder();
                });

                connection.on("UserLeft", (connId) => {
                console.log("User left:", connId);
                removePeerConnection(connId);
                updateGridPlaceholder();
                });

                connection.on("ReceiveOffer", async (fromId, offer) => {
                console.log("Received offer from:", fromId);
                const pc = await createPeerConnection(fromId, false);
                await pc.setRemoteDescription(new RTCSessionDescription(offer));
                const answer = await pc.createAnswer();
                await pc.setLocalDescription(answer);
                await connection.invoke("SendAnswer", fromId, answer);
                });

                connection.on("ReceiveAnswer", async (fromId, answer) => {
                console.log("Received answer from:", fromId);
                const pc = pcs[fromId];
                if (pc) {
                await pc.setRemoteDescription(new RTCSessionDescription(answer));
                }
                });

                connection.on("ReceiveIceCandidate", async (fromId, candidate) => {
                console.log("Received ICE from:", fromId);
                const pc = pcs[fromId];
                if (pc) {
                await pc.addIceCandidate(new RTCIceCandidate(candidate));
                }
                });

                connection.on("JoinRequest", (connId, name) => {
                if (!isHost) return; // Only host should see and handle join requests

                console.log("Join request received by host from:", name);
                pendingJoiner = connId;
                const toast = document.getElementById('admissionToast');
                if (toast) {
                document.getElementById('admissionMsg').innerText = `${name} is knocking...`;
                toast.style.display = 'flex';
                }
                });

                connection.on("JoinAccepted", async (roomId, visibility) => {
                console.log("✅ Join ACCEPTED for room:", roomId, "Visibility:", visibility);
                isHost = false;
                try {
                console.log("Invoking JoinRoom as guest with:", { roomId, userName, userOrg, visibility });
                await connection.invoke("JoinRoom", roomId, userName, userOrg, visibility);
                console.log("✅ JoinRoom call successful");
                } catch (err) {
                console.error("❌ JoinRoom execution failed:", err);
                alert("Critical: Could not enter the meeting room even after host approval. " + err.message);
                }
                });

                connection.onreconnecting(error => {
                console.warn("SignalR Reconnecting:", error);
                });

                connection.onreconnected(connectionId => {
                console.log("SignalR Reconnected:", connectionId);
                });

                connection.onclose(error => {
                console.error("SignalR Connection closed:", error);
                });

                connection.on("JoinRejected", () => {
                alert("The host denied your join request.");
                location.reload();
                });

                connection.on("MediaStatusChanged", (connId, isCameraOn, isMicOn) => {
                console.log(`Media status changed for ${connId}: Cam=${isCameraOn}, Mic=${isMicOn}`);
                const camBtn = document.getElementById(`vCam_${connId}`);
                const micBtn = document.getElementById(`vMic_${connId}`);

                if (camBtn) {
                if (isCameraOn) {
                camBtn.classList.add('v-btn-active');
                camBtn.classList.remove('v-btn-inactive');
                camBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 7l-7 5 7 5V7z"></path><rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect></svg>';
                } else {
                camBtn.classList.add('v-btn-inactive');
                camBtn.classList.remove('v-btn-active');
                camBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 16v1a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h2m5.66 0H14a2 2 0 0 1 2 2v3.34l1 1L23 7v10"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>';
                }
                }
                if (micBtn) {
                if (isMicOn) {
                micBtn.classList.add('v-btn-active');
                micBtn.classList.remove('v-btn-inactive');
                micBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"></path><path d="M19 10v2a7 7 0 0 1-14 0v-2"></path><line x1="12" y1="19" x2="12" y2="23"></line><line x1="8" y1="23" x2="16" y2="23"></line></svg>';
                } else {
                micBtn.classList.add('v-btn-inactive');
                micBtn.classList.remove('v-btn-active');
                micBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="1" y1="1" x2="23" y2="23"></line><path d="M9 9v3a3 3 0 0 0 5.12 2.12M15 9.34V4a3 3 0 0 0-5.94-.6"></path><path d="M17 16.95A7 7 0 0 1 5 12v-2m14 0v2a7 7 0 0 1-.11 1.23"></path><line x1="12" y1="19" x2="12" y2="23"></line><line x1="8" y1="23" x2="16" y2="23"></line></svg>';
                }
                }
                });

                connection.on("Kicked", () => {
                alert("You have been removed from the meeting by the host.");
                endCall();
                });

                connection.on("ReceiveMessage", (user, message, time) => {
                const isMe = (user === userName);
                const div = document.createElement('div');
                const isSignMessage = typeof message === 'string' && message.startsWith('[SIGN] ');
                div.className = `message ${isMe ? 'sent' : 'received'}${isSignMessage ? ' sign-message' : ''}`;
                const displayMessage = isSignMessage ? message.replace('[SIGN] ', '') : message;

                div.innerHTML = `
                ${!isMe ? `<div class="user">${user}</div>` : ''}
                <div class="text">${displayMessage}</div>
                <div class="time">${time}</div>
                `;

                const messages = document.getElementById('messages');
                messages.appendChild(div);
                messages.scrollTop = messages.scrollHeight;
                });

                connection.on("UpdateUserCount", (count) => {
                const badge = document.querySelector('#participantBadge span');
                if (badge) badge.innerText = count;
                });

                function toggleCamera() {
                if (!localStream) return;
                const track = localStream.getVideoTracks()[0];
                if (track) {
                track.enabled = !track.enabled;
                const vBtn = document.getElementById('vCam_local');
                if (track.enabled) {
                if (vBtn) {
                vBtn.classList.add('v-btn-active'); vBtn.classList.remove('v-btn-inactive');
                vBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 7l-7 5 7 5V7z"></path><rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect></svg>';
                }
                updateAvatarState(false);
                }
                else {
                if (vBtn) {
                vBtn.classList.add('v-btn-inactive'); vBtn.classList.remove('v-btn-active');
                vBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 16v1a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h2m5.66 0H14a2 2 0 0 1 2 2v3.34l1 1L23 7v10"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>';
                }
                updateAvatarState(true);
                }
                notifyMediaStatus();
                }
                }

                function toggleMic() {
                if (!localStream) return;
                const t = localStream.getAudioTracks()[0];
                if (t) {
                t.enabled = !t.enabled;
                const vBtn = document.getElementById('vMic_local');
                if (t.enabled) {
                if (vBtn) {
                vBtn.classList.add('v-btn-active'); vBtn.classList.remove('v-btn-inactive');
                vBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"></path><path d="M19 10v2a7 7 0 0 1-14 0v-2"></path><line x1="12" y1="19" x2="12" y2="23"></line><line x1="8" y1="23" x2="16" y2="23"></line></svg>';
                }
                }
                else {
                if (vBtn) {
                vBtn.classList.add('v-btn-inactive'); vBtn.classList.remove('v-btn-active');
                vBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="1" y1="1" x2="23" y2="23"></line><path d="M9 9v3a3 3 0 0 0 5.12 2.12M15 9.34V4a3 3 0 0 0-5.94-.6"></path><path d="M17 16.95A7 7 0 0 1 5 12v-2m14 0v2a7 7 0 0 1-.11 1.23"></path><line x1="12" y1="19" x2="12" y2="23"></line><line x1="8" y1="23" x2="16" y2="23"></line></svg>';
                }
                }
                notifyMediaStatus();
                }
                }

                async function notifyMediaStatus() {
                if (!localStream || !currentRoomId || connection.state !== signalR.HubConnectionState.Connected) return;
                const camOn = localStream.getVideoTracks().length > 0 && localStream.getVideoTracks()[0].enabled;
                const micOn = localStream.getAudioTracks().length > 0 && localStream.getAudioTracks()[0].enabled;
                try {
                await connection.invoke("UpdateMediaStatus", currentRoomId, camOn, micOn);
                } catch (err) {
                console.error("Failed to sync media status:", err);
                }
                }

                async function kickUser(targetId) {
                if (!isHost || !currentRoomId) return;
                if (confirm("Are you sure you want to remove this user from the meeting?")) {
                try {
                await connection.invoke("KickUser", currentRoomId, targetId);
                } catch (err) {
                console.error("Failed to kick user:", err);
                }
                }
                }

                function endCall() {
                if (localStream) { localStream.getTracks().forEach(t => t.stop()); localStream = null; }
                stopSignDetection();
                Object.keys(pcs).forEach(id => removePeerConnection(id));
                if (isFullScreen()) exitFullScreen().finally(() => { document.getElementById('meetingScreen').style.display = 'none'; document.getElementById('startScreen').style.display = 'flex'; });
                else { document.getElementById('meetingScreen').style.display = 'none'; document.getElementById('startScreen').style.display = 'flex'; }
                document.getElementById('messages').innerHTML = '';
                location.reload(); // Refresh to clear state
                }

                async function sendMessage() {
                const input = document.getElementById('messageInput'); const text = input.value.trim();
                if (!text) return;
                try {
                await connection.invoke("SendMessage", currentRoomId, userName, text);
                input.value = '';
                } catch (err) {
                console.error(err);
                }
                }

                // Admission Helpers
                async function handleAdmission(accepted) {
                console.log("Host handled admission:", accepted ? "ACCEPTED" : "DENIED");
                document.getElementById('admissionToast').style.display = 'none';
                if (accepted) {
                console.log("Invoking AcceptJoin for:", pendingJoiner);
                await connection.invoke("AcceptJoin", pendingJoiner, currentRoomId);
                } else {
                console.log("Invoking RejectJoin for:", pendingJoiner);
                await connection.invoke("RejectJoin", pendingJoiner);
                }
                pendingJoiner = null;
                }

                // Grid/UI Helpers
                function getOrCreateVideoBox(targetId, name) {
                let videoBox = document.getElementById(`box_${targetId}`);
                if (!videoBox) {
                videoBox = document.createElement('div');
                videoBox.className = 'videoBox';
                videoBox.id = `box_${targetId}`;

                const initials = (name || "U").charAt(0).toUpperCase();

                videoBox.innerHTML = `
                <div class="user-overlay">${name || 'Guest'}</div>
                <div style="position: absolute; top: 10px; right: 10px; display: flex; gap: 5px; z-index: 10;">
                <button class="pip-btn" style="position: static;" onclick="toggleElementFullScreen('box_${targetId}')" title="Toggle Fullscreen">⤢</button>
                </div>
                <button id="signBtn_${targetId}" class="sign-detect-btn" onclick="toggleSignDetection('${targetId}')" title="Sign Detection">🤟</button>
                <div class="avatar-overlay" id="avatar_${targetId}" style="display: flex">
                <div class="avatar-circle">${initials}</div>
                </div>
                <video id="video_${targetId}" autoplay playsinline></video>
                <canvas id="signCanvas_${targetId}" class="sign-landmark-canvas"></canvas>
                <!-- Per-Video Controls (Remote) -->
                <div class="video-controls-overlay">
                <!-- Camera & mic reflect remote user status; not clickable by local user to toggle remote hardware -->
                <button id="vCam_${targetId}" class="v-btn-active" style="cursor: default;" title="${name}'s Camera">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 7l-7 5 7 5V7z"></path><rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect></svg>
                </button>
                <button id="vMic_${targetId}" class="v-btn-active" style="cursor: default;" title="${name}'s Microphone">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"></path><path d="M19 10v2a7 7 0 0 1-14 0v-2"></path><line x1="12" y1="19" x2="12" y2="23"></line><line x1="8" y1="23" x2="16" y2="23"></line></svg>
                </button>
                <!-- Only host sees the End Call (kick) button for guests -->
                <button class="v-btn-end ${isHost ? '' : 'v-btn-hidden'}" onclick="kickUser('${targetId}')" title="Kick User">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.68 13.31a16 16 0 0 0 3.41 2.6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7 2 2 0 0 1 1.72 2v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.42 19.42 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91"></path><line x1="23" y1="1" x2="1" y2="23"></line></svg>
                </button>
                </div>
                `;

                const grid = document.getElementById('videoGrid') || document.querySelector('.videoGrid');
                if (grid) {
                grid.appendChild(videoBox);
                console.log("Appended video box for:", targetId);
                }
                }
                return videoBox;
                }

                function updateGridPlaceholder() {
                const grid = document.getElementById('videoGrid');
                const placeholder = document.getElementById('emptyGridMsg');
                const peerBoxes = grid.querySelectorAll('.videoBox:not(#localVideoBox)');

                const totalBoxes = peerBoxes.length + 1; // including localVideoBox
                grid.classList.remove('grid-1', 'grid-2', 'grid-3', 'grid-4', 'grid-plus');
                if (totalBoxes === 1) grid.classList.add('grid-1');
                else if (totalBoxes === 2) grid.classList.add('grid-2');
                else if (totalBoxes === 3) grid.classList.add('grid-3');
                else if (totalBoxes === 4) grid.classList.add('grid-4');
                else grid.classList.add('grid-plus');

                if (peerBoxes.length === 0) {
                placeholder.style.display = 'block';
                } else {
                placeholder.style.display = 'none';
                }
                }

                // Advanced UI Helpers

                function updateAvatarState(isOff) {
                const avatar = document.getElementById('localAvatar');
                if (isOff) avatar.style.display = 'flex';
                else avatar.style.display = 'none';
                }

                function restoreChatToDefaultPosition() {
                const chat = document.getElementById('mainChat');
                const videoGrid = document.getElementById('videoGrid');
                if (!chat || !videoGrid) return;

                // Keep chat directly below the video grid in normal mode.
                if (videoGrid.nextElementSibling !== chat) {
                videoGrid.insertAdjacentElement('afterend', chat);
                }
                }

                function isFullScreen() { return !!(document.fullscreenElement || document.webkitFullscreenElement || document.msFullscreenElement); }
                function onFullScreenChange() {
                const fsBtn = document.getElementById('fsBtn');
                const isFS = isFullScreen();
                if (fsBtn) fsBtn.textContent = isFS ? '⤡ Exit Fullscreen' : '⤢ Fullscreen App';

                if (!isFS) {
                restoreChatToDefaultPosition();
                }
                }

                async function toggleElementFullScreen(id) {
                const el = document.getElementById(id);
                if (!el) return;

                if (!isFullScreen()) {
                // If this is a video box, move chat into it before entering fullscreen
                if (el.classList.contains('videoBox')) {
                const chat = document.getElementById('mainChat');
                if (chat) el.appendChild(chat);
                }
                await enterFullScreen(el);
                } else {
                await exitFullScreen();
                restoreChatToDefaultPosition();
                }
                }

                function enterFullScreen(el) { if (el.requestFullscreen) return el.requestFullscreen(); if (el.webkitRequestFullscreen) return el.webkitRequestFullscreen(); if (el.msRequestFullscreen) return el.msRequestFullscreen(); return Promise.reject(); }
                function exitFullScreen() { if (document.exitFullscreen) return document.exitFullscreen(); if (document.webkitExitFullscreen) return document.webkitExitFullscreen(); if (document.msExitFullscreen) return document.msExitFullscreen(); return Promise.reject(); }

                function generateRoomId() { return Math.random().toString(36).slice(2, 9); }
                function buildMeetingUrl(roomId) { return `${location.origin}/Call/Index?room=${encodeURIComponent(roomId)}`; }

                function showLinkModal(link) {
                const modal = document.getElementById('linkModal');
                document.getElementById('modalMeetingLink').value = link;
                document.getElementById('openMeetingLink').href = link;
                modal.style.display = 'flex';
                modal.setAttribute('aria-hidden', 'false');
                }
                function closeLinkModal() { const modal = document.getElementById('linkModal'); modal.style.display = 'none'; modal.setAttribute('aria-hidden', 'true'); }
                async function copyModalLink() {
                const link = document.getElementById('modalMeetingLink').value; if (!link) return;
                if (navigator.clipboard && navigator.clipboard.writeText) { try { await navigator.clipboard.writeText(link); alert('Link copied to clipboard'); } catch (err) { prompt('Copy link:', link); } } else prompt('Copy link:', link);
                }
                function sendModalViaWhatsApp() {
                const link = document.getElementById('modalMeetingLink').value; if (!link) return;
                const wa = `https://api.whatsapp.com/send?text=${encodeURIComponent('Join my video call: ' + link)}`; window.open(wa, '_blank');
                }

                async function copyMeetingLink() {
                const link = buildMeetingUrl(currentRoomId);
                if (!link) return alert('No meeting link available');
                if (navigator.clipboard && navigator.clipboard.writeText) {
                try { await navigator.clipboard.writeText(link); alert('Link copied to clipboard'); }
                catch (e) { prompt('Copy link:', link); }
                } else {
                prompt('Copy link:', link);
                }
                }
                function openShareModal() {
                const link = buildMeetingUrl(currentRoomId);
                if (!link) return;
                showLinkModal(link);
                }

                function toggleOrgInput() {
                refreshStartFields();
                }

                (async function prefillRoomFromQuery() {
                const params = new URLSearchParams(window.location.search); const room = params.get('room');
                if (room) {
                document.getElementById('inviteRoomInput').value = room;
                const invitedNote = document.getElementById('invitedNote');
                invitedNote.style.display = 'block';

                try {
                if (connection.state === signalR.HubConnectionState.Disconnected) {
                await connection.start();
                }
                const info = await connection.invoke("GetRoomInfo", room);
                invitedRoomVisibility = (info && (info.visibility || info.Visibility)) || "";
                } catch (err) {
                console.warn("Could not load room visibility before join:", err);
                invitedRoomVisibility = "";
                }

                if (invitedRoomVisibility === "org") {
                invitedNote.textContent = `You were invited to room: ${room}. Enter your name and organization to join.`;
                } else {
                invitedNote.textContent = `You were invited to room: ${room}. Enter your name to join.`;
                }
                }
                refreshStartFields();
                })();
            </script>
        </body>

    </html>

